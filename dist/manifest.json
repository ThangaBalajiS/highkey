{
  "manifest_version": 3,
  "name": "Highkey - The Visual Binder",
  "version": "1.0.0",
  "description": "Assign custom keyboard shortcuts to any UI element without CSS selectors.",
  "icons": {
    "128": "public/icon.svg"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "public/icon.svg"
  },
  "options_page": "src/dashboard/index.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.ts-loader.js"
      ]
    }
  ],
  "commands": {
    "activate-binder": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Activate the Visual Binder"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "**/*",
        "*"
      ],
      "use_dynamic_url": false
    }
  ]
}
