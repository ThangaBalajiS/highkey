{
  "manifest_version": 3,
  "name": "Highkey - The Visual Binder",
  "version": "1.0.0",
  "description": "Assign custom keyboard shortcuts to any UI element without CSS selectors.",
  "icons": {
    "16": "public/logo_16.png",
    "32": "public/logo_32.png",
    "48": "public/logo_48.png",
    "128": "public/logo_128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "public/logo_48.png"
  },
  "options_page": "src/dashboard/index.html",
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "commands": {
    "activate-binder": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Activate the Visual Binder"
    }
  }
}
